# BookPoint — environment variable reference
#
# Copy this file to .env and fill in real values.
# Never commit .env to version control.
# All variables are optional; defaults are shown in comments.

# ---------------------------------------------------------------------------
# Secret key — REQUIRED in production
# ---------------------------------------------------------------------------

# Random string (≥ 32 characters) used to sign session cookies and CSRF tokens.
# Generate one with:  python -c "import secrets; print(secrets.token_urlsafe(48))"
# If unset, a key is auto-generated and stored in .bookpoint_secret (local dev only).
ACCOUNTING_SECRET_KEY=

# Path to the auto-generated local secret file (alternative to ACCOUNTING_SECRET_KEY).
# Default: .bookpoint_secret in the working directory.
# ACCOUNTING_SECRET_FILE=.bookpoint_secret

# ---------------------------------------------------------------------------
# Database
# ---------------------------------------------------------------------------

# Absolute path to the SQLite database file.
# Default: /data/accounting.db  (suitable for Fly.io persistent volumes)
# Local development example:
# ACCOUNTING_DB=/home/user/bookpoint/data/accounting.db
ACCOUNTING_DB=/data/accounting.db

# ---------------------------------------------------------------------------
# HTTPS / TLS
# ---------------------------------------------------------------------------

# Set to "1" in production to enable HSTS headers and the Secure cookie flag.
# Leave unset (or "0") for local HTTP development.
ACCOUNTING_HTTPS=0

# ---------------------------------------------------------------------------
# Session lifetime
# ---------------------------------------------------------------------------

# Session cookie lifetime in seconds.  Default: 43200 (12 hours).
ACCOUNTING_SESSION_SECONDS=43200

# ---------------------------------------------------------------------------
# Password hashing
# ---------------------------------------------------------------------------

# PBKDF2-HMAC-SHA256 iteration count.  Default: 260000.
# Increasing this value does NOT invalidate existing password hashes.
ACCOUNTING_PBKDF2_ITERATIONS=260000

# ---------------------------------------------------------------------------
# Brute-force / account lockout
# ---------------------------------------------------------------------------

# Consecutive failed login attempts before an account is locked.  Default: 5.
ACCOUNTING_MAX_LOGIN_ATTEMPTS=5

# How long (minutes) a locked account stays locked.  Default: 15.
ACCOUNTING_LOCKOUT_MINUTES=15

# ---------------------------------------------------------------------------
# IP-level rate limiting (login endpoint)
# ---------------------------------------------------------------------------

# Maximum login attempts per IP within the rate-limit window.  Default: 20.
ACCOUNTING_IP_RATE_LIMIT=20

# Sliding window length (minutes) for IP rate limiting.  Default: 15.
ACCOUNTING_IP_RATE_WINDOW_MINUTES=15

# ---------------------------------------------------------------------------
# File uploads
# ---------------------------------------------------------------------------

# Base directory for uploaded request attachments.
# Default: <project root>/uploads  (resolved at runtime when unset).
# ACCOUNTING_UPLOAD_DIR=/data/uploads

# ---------------------------------------------------------------------------
# Email / SMTP (for notifications and password-reset emails)
# ---------------------------------------------------------------------------

SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=noreply@example.com
SMTP_FROM=noreply@example.com
SMTP_PASSWORD=
# Set to "0" to disable STARTTLS (not recommended).
SMTP_TLS=1

# ---------------------------------------------------------------------------
# Application base URL (used to build absolute links in email notifications)
# ---------------------------------------------------------------------------

# Full base URL without a trailing slash.
# Example: https://bookpoint.fly.dev
# Leave unset for local development; email links will be relative.
APP_BASE_URL=
